# ─────────────────────────────────────────────────────────────────────────────
# Supabase — Required
# Get from: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# App config
# VITE_APP_URL must match the Site URL in Supabase → Authentication → URL Configuration.
# Update to your production URL before deploying.
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_NAME=TravelMate
VITE_APP_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Geoapify Places API — Required for Nearby Places feature
# Get a free key at: https://myprojects.geoapify.com → New Project → API Key
# Free tier: 3,000 requests/day. Safe to expose (domain-restrict in the Geoapify console).
# ─────────────────────────────────────────────────────────────────────────────
VITE_GEOAPIFY_API_KEY=your-geoapify-api-key

# ─────────────────────────────────────────────────────────────────────────────
# AI provider label — frontend display only, does NOT expose any API key.
# The actual provider routing happens inside the Supabase Edge Function.
# Options: groq | gemini | openrouter
# ─────────────────────────────────────────────────────────────────────────────
VITE_AI_PROVIDER=groq

# ─────────────────────────────────────────────────────────────────────────────
# The following secrets are set via Supabase CLI or Dashboard → Edge Functions → Secrets.
# They are NEVER stored in this file or any frontend file.
#
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# ─────────────────────────────────────────────────────────────────────────────
